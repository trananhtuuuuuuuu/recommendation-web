{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Docker Debugger",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005,
            "preLaunchTask": "docker-compose: debug up"
        },
        {
            "type": "java",
            "name": "Local Debugger",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "DATN.backend.BackendApplication",
            "projectName": "backend",
            "args": "",
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}